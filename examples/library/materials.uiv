[version]
format: 0.1.0
unit_frame: si_metric.ut
note: "Standard library for PyFea useful for standard multi-physics problems"

[standards]
temperature:    298.15 (K)
pressure:       101.32 k(Pa)
note: "Standard lab conditions - unless overwritten by material"




[vacuum.meta]
type: "empty_space"

[vacuum.physical]
density: 0 (kg/m^3)
absolute_viscosity: 0 (Pa*s)

[vacuum.chemical]
molar_mass: 0 (kg/mol)

[vacuum.electrical]
relative_permittivity: [1, 1]

# High vacuum (200uPa): https://en.wikipedia.org/wiki/Dielectric_strength
dielectric_breakdown: 30 M(V/m)

temperature_conductivity: [
  [200.0, 0],
  [700.0, 0],
  [1200.0, 0],
  [1700.0, 0],
] (K), (S_m)

[vacuum.magnetic]
relative_permeability: [1.0, 1.0]

[vacuum.thermal]
specific_heat: 0 (c)
temperature_conductivity: [
  [200.0, 0],
  [800.0, 0],
  [1600.0, 0],
  [2000.0, 0]
] (K), (k)





