[NdFeB.meta]
type: "magnet_material"
composition: "Sintered: Neodymium, Iron, Boron"
temperature_grade: "Standard - non high temperature resistance"
note: "matweb.com: `Alliance N-52 Sintered NdFeB Neodymium Magnet`; femm: N30-55 Series"

[NdFeB.chemical]
molar_mass: 1081.19 m(kg/mol)

[NdFeB.physical]
density: 7500 (kg/m^3)

# https://e-magnetsuk.com/introduction-to-neodymium-magnets/characteristics-of-ndfeb-magnets/
# NOTE: bulk modulus -> k= tensile_strength / (3-6poisson_ratio), Assumes yield == tensile.
poisson_ratio:      0.24
shear_modulus:      64.0 G(Pa)
yield_strength:     80.0 M(Pa)
tensile_strength:   80.0 M(Pa)
youngs_modulus:     160.0 G(Pa)
bulk_modulus:       102.6 G(Pa)


[NdFeB.electrical]
relative_permittivity: [1, 1]

# Constructed table via p(t) = p_o * (1 + a * (t-to)); p_o = 0.667 M(S/m)
temperature_conductivity: [
  [273.0, 0.697],
  [293.0, 0.667],
  [323.0, 0.663],
  [373.0, 0.656],
  [423.0, 0.649],
  [473.0, 0.643]
] (K), M(S_m)

[NdFeB.magnetic]
relative_permeability: [1.05, 1.05]
curie_temperature: 583.15 (K)

# Refer: https://smmagnetics.com/pages/neodymium-material-specs
# Temperature coefficients: %/K
alpha_remanence: -0.12 (K^-1)
beta_coercivity: -0.6 (K^-1)

[NdFeB.grades]
N30: [0.836, 1.10]   M(A_m), (T)
N33: [0.879, 1.14]   M(A_m), (T)
N35: [0.906, 1.17]   M(A_m), (T)
N38: [0.945, 1.22]   M(A_m), (T)
N40: [0.970, 1.25]   M(A_m), (T)
N42: [0.995, 1.28]   M(A_m), (T)
N45: [1.030, 1.32]   M(A_m), (T)
N48: [1.015, 1.37]   M(A_m), (T)
N50: [0.988, 1.40]   M(A_m), (T)
N52: [0.956, 1.43]   M(A_m), (T)
N55: [0.923, 1.47]   M(A_m), (T)

[NdFeB.thermal]
specific_heat: 460 (c)
max_working_tem: 353.15 (K)
reference_temperature: 298.15 (K)

# Refer: https://www.arnoldmagnetics.com/wp-content/uploads/2017/10/Catalog-151021.pdf
# Constructed table via p(t) = p_o * (1 + a * (t-to)); p_o = 7.6 (k)
temperature_conductivity: [
  [273.0, 7.83],
  [293.0, 7.60],
  [323.0, 7.14],
  [373.0, 6.38],
] (K), (k)




[silica.meta]
